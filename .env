# ============================================================
# Copie este arquivo para ".env" e ajuste os valores.
# NUNCA coloque senhas aqui — senhas ficam no Credentials Vault.
# ============================================================

# Diretórios (relativos à raiz do projeto) — nada hardcoded no código
DADOS_ENTRADA_DIR=dados_entrada
LOGS_DIR=logs
CSV_ENTRADA=usuarios_auditoria.csv

# BotCity Maestro
# Deixe MAESTRO_ENABLED=false / VAULT_ENABLED=false para rodar 100% localmente
# durante o desenvolvimento e testes (o bot usa um stub offline).
MAESTRO_ENABLED=false
VAULT_ENABLED=false
MAESTRO_SERVER=https://your-server.botcity.dev
MAESTRO_LOGIN=seu_login_maestro
MAESTRO_KEY=sua_key_maestro

# Nomes usados dentro do Maestro
DATAPOOL_LABEL=FilaAuditoriaRH
CREDENTIAL_LABEL=credencial_erp
